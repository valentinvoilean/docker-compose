# Copy to .env next to this compose file, or set these in Portainer -> Stack -> Environment variables.
# Do not commit .env to git.

# Required (host paths)
OPENCLAW_CONFIG_DIR=/home/open-claw/config
OPENCLAW_WORKSPACE_DIR=/home/open-claw/workspace

# Required (gateway auth + public URL)
OPENCLAW_GATEWAY_TOKEN=changeme
OPENCLAW_PUBLIC_URL=https://openclaw.example.com

# Host bind for LAN access
OPENCLAW_BIND_ADDR=0.0.0.0
OPENCLAW_PORT=18789

# Optional image override (default: ghcr.io/openclaw/openclaw:latest)
# OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# Optional AI provider keys (set only the ones you use)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# Optional Ollama endpoint (default points to host)
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_HOST=http://host.docker.internal:11434
