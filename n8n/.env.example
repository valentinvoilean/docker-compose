# n8n image tag. Use "stable" for normal self-hosting, or pin a specific version.
N8N_VERSION=stable

# Host port for LAN access, for example http://<nas-lan-ip>:5678.
N8N_PORT=5678

# Host folder where n8n stores config, encryption metadata, and local files.
N8N_DATA_HOST_PATH=/share/Container/n8n/data

# Container timezone. Keep this aligned with your location.
TZ=Europe/Bucharest

# n8n workflow timezone, used by schedule/cron-style nodes.
GENERIC_TIMEZONE=Europe/Bucharest

# Long random secret used to encrypt credentials in the database. Do not change after first use.
N8N_ENCRYPTION_KEY=replace-with-a-long-random-string

# Extra browser-level login before n8n loads. Usually false if Cloudflare Access protects it.
N8N_BASIC_AUTH_ACTIVE=true

# Username for the optional basic auth gate above.
N8N_BASIC_AUTH_USER=admin

# Password for the optional basic auth gate above. Not the same as your n8n user password.
N8N_BASIC_AUTH_PASSWORD=replace-with-a-strong-password

# Public Cloudflare/reverse-proxy URL n8n should use when generating webhook URLs.
N8N_WEBHOOK_URL=https://n8n.example.com/

# Number of trusted reverse proxies in front of n8n. Use 1 for Cloudflare Tunnel/reverse proxy.
N8N_PROXY_HOPS=1

# Postgres image tag.
POSTGRES_VERSION=16-alpine

# Database name n8n will use.
POSTGRES_DB=n8n

# Database user n8n will connect as.
POSTGRES_USER=n8n

# Database password for POSTGRES_USER.
POSTGRES_PASSWORD=replace-with-a-strong-password

# Host folder where Postgres stores the database files. Keep this dedicated to Postgres.
POSTGRES_DATA_HOST_PATH=/share/Container/n8n/postgres
