# Copy to .env next to this compose file, or set these in Portainer → Stack → Environment variables.
# Do not commit .env to git.

# Optional image tag (default: latest)
# VAULTWARDEN_VERSION=latest

# Web UI (host side → container port 80)
# Default 8088 — 8080 is often taken by NAS / other stacks; override if needed
VAULTWARDEN_PORT=8088

# Persistent data (create folder first on NAS if using an absolute path)
VAULTWARDEN_DATA_HOST_PATH=/share/Container/vaultwarden

# After creating your account, set false so strangers cannot register
VAULTWARDEN_SIGNUPS_ALLOWED=true

# When using a reverse proxy with HTTPS, set your public URL (example):
VAULTWARDEN_DOMAIN=https://vault.example.com

# Optional: strong random token for /admin (only after DOMAIN is correct)
# VAULTWARDEN_ADMIN_TOKEN=

TZ=Europe/Bucharest
