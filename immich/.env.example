# Copy to .env next to this compose file, or set these in Portainer → Stack → Environment variables.
# Do not commit .env to git.

# Required (paths on the NAS / host)
UPLOAD_LOCATION=/share/Container/immich/upload
DB_DATA_LOCATION=/share/Container/immich/postgres

# Required (Postgres)
DB_PASSWORD=changeme
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

# Optional: immich-server and immich-machine-learning image tag (default: release)
# IMMICH_VERSION=release
