# Copy to .env next to this compose file, or set these in Portainer → Stack → Environment variables

# Web UI (host side)
METUBE_PORT=8081

# Where finished files land on the NAS (create this folder first in File Station)
METUBE_DOWNLOADS_HOST_PATH=/share/Container/metube/downloads

# Match ownership to the user that should own files on the share (SSH: id <user>)
PUID=1000
PGID=100

TZ=Europe/Bucharest
UMASK=022

# If QNAP still errors on .metube after a host chown, set false (see README).
# CHOWN_DIRS=false
